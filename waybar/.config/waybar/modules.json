{
  // === Hyprland Workspaces ===
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{id}",
    "format-icons": {
      "default": "´äî",
      "active": "´åÆ",
      "urgent": "´ü¬"
    }
  },

  // Current window title
  "hyprland/window": {
    "separate-outputs": true,
    "max-length": 50
  },

  // Arch Rofi launcher
  "custom/arch-logo": {
    "format": " ",
    "tooltip": false,
    "on-click": "rofi -show drun"
  },

  // Exit / Power menu
  "custom/exit": {
    "format": "´Çæ",
    "on-click": "wlogout",
    "tooltip-format": "Power Menu"
  },

  // Clock
  "clock": {
    "format": "´Çù  {:%I:%M %p}",
    "format-alt": "´ü│  {:%a, %b %d}",
    "timezone": "Asia/Manila",
    "on-click-right": "gnome-calendar",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "format": "´Æ╝  {usage}%",
    "tooltip": true
  },

  // Memory
  "memory": {
    "format": "¾░ıø  {}%",
    "tooltip": true
  },

  // Disk
  "disk": {
    "interval": 30,
    "format": "´éá  {percentage_used}%",
    "on-click": "kitty -e htop",
    "path": "/"
  },

  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["disk", "cpu", "memory"]
  },

  // Network
  "network": {
    "format-wifi": "´ç½   {essid}",
    "format-ethernet": "¾░êÇ  {ifname}",
    "format-disconnected": "ÔÜá Disconnected",
    "tooltip-format-wifi": "´ç½ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%",
    "tooltip-format-ethernet": "¾░êÇ {ifname}\nIP: {ipaddr}",
    "on-click": "kitty --title nmtui --override background_opacity=1.0 --override background=#1a1b26 --override foreground=#cdd6f4 --override color0=#1a1b26 --override color1=#f38ba8 --override color2=#a6e3a1 --override color3=#f9e2af --override color4=#89b4fa --override color5=#cba6f7 --override color6=#94e2d5 --override color7=#cdd6f4 --override color8=#585b70 --override color9=#f38ba8 --override color10=#a6e3a1 --override color11=#f9e2af --override color12=#89b4fa --override color13=#cba6f7 --override color14=#94e2d5 --override color15=#b4befe -e nmtui"
  },

  // Battery
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 30,
    "format": "{icon}  {capacity}%",
    "format-charging": "´çĞ {capacity}%",
    "format-plugged": "´çĞ {capacity}%",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },

  // Audio
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "´æĞ Muted",
    "on-click": "pavucontrol",
    "format-icons": {
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },

  // Music visualizer (cava)
  "custom/cava": {
    "exec": "~/.config/waybar/cava.sh",
    "format": "{}",
    "tooltip": false,
    "escape": false
  },

  // Bluetooth
  "bluetooth": {
    "format": "´èô {status}",
    "format-disabled": "",
    "format-no-controller": "",
    "hide-if-disabled": true,
    "interval": 30,
    "on-click": "blueman-manager"
  }
}
